<rules lang="tl" xsi:noNamespaceSchemaLocation="../rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<category id="2WordsMerged" name="Two Words Merged into One Change">
		<rule id="PANGHALIP-PANGHALIP" name="PP P(_)P">
			<pattern case_sensitive="no" mark_from="0">
				<!-- Added kaba in exception because it is ambigious to the tagalog word kaba so it has to be checked with a question mark to verify -->
				<marker>
					<token regexp="yes">\b([pkmn][ao]|na)(lang|ko|ba|[dr](in|aw|ito))\b<exception regexp="yes">kaba</exception></token>
				</marker>
			</pattern>

			<message> Ang ibig sabihin mo ba ay
				<suggestion><match no="1" case_conversion="startlower" regexp_match="(..)(.*)" regexp_replace="$1 $2"/></suggestion>? Walang salitang '<match no="1"/>'.
			</message>
			<short>Two Words Merged into One Change</short>
			<example correction="pa rin" type="incorrect">Nandito ka <marker>palang</marker></example>
			<example type="correct">Nandito ka <marker>pa lang</marker></example>
		</rule>
		
	</category>
	<category id="VowelReduction" name="'oo' being turned to 'o' or 'u'">
		<rule id="GANON" name="ganon to ganoon">
			<pattern>
			<token regexp="yes">\bganon|ganun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'ganoon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>ganoon</suggestion>
		</rule>

		<rule id="DON" name="don to doon">
			<pattern>
			<token regexp="yes">\bdon|dun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'doon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>doon</suggestion>
		</rule>

		<rule id="NON" name="non to noon">
			<pattern>
			<token regexp="yes">\bnon|nun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'noon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>noon</suggestion>
		</rule>

		<rule id="NANDOON" name="andon to nandoon">
			<pattern>
			<token regexp="yes">\bandon|andun|nandon|nandun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'nandoon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>nandoon</suggestion>
		</rule>

		<rule id="PAPANO" name="papano to paano">
			<pattern>
			<token regexp="yes">\bpapano\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'paano'? Walang salitang '<match no="1"/>'</message>
			<suggestion>paano</suggestion>
		</rule>

		<rule id="NARUN" name="narun to naroon">
			<pattern>
			<token regexp="yes">\bnarun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'naroon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>naroon</suggestion>
		</rule>

		<rule id="PARUN" name="parun to paroon">
			<pattern>
			<token regexp="yes">\bparun\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'paroon'? Walang salitang '<match no="1"/>'</message>
			<suggestion>paroon</suggestion>
		</rule>

		<rule id="NUNG" name="nung to noong">
			<pattern>
			<token regexp="yes">\bnung\b</token>
			</pattern>
			<message>Ang ibig sabihin mo ba ay 'noong'? Walang salitang '<match no="1"/>'</message>
			<suggestion>noong</suggestion>
		</rule>
	</category>
	<category id="VowelCorrection" name="E to I vowel change">
		<rule id="-ET" name="ET->IT">
			<pattern case_sensitive="no" mark_from="0">
				<token regexp="yes">\w*([b-df-hj-np-tv-z]|[aeiou])et$</token> <!--this index=0-->
			</pattern>
			<message> Do you mean 
				<suggestion><match no="1" case_conversion="startlower" regexp_match="(.*)e(.)" regexp_replace="$1i$2"/></suggestion>? 
							Based on most Filipino words, and according to the KWF Dictionary,
							<match no="1" /> should end with "-it".
			</message>
			<short>Spelling Change</short>
			<example correction="damit" type="incorrect">Hala! Lumilipad na mga <marker>damet</marker> natin!</example>
			<example correction="pangit" type="incorrect">Kinuha ko ito kahit <marker>panget</marker>.</example>
			<example correction="mabait" type="incorrect"><marker>Mabaet</marker> pa pala ang paggamit nang jumper.</example>
			<example type="correct">Hindi siya ganoong <marker>kapait</marker> tulad ng kinain natin kahapon. </example>
			<example type="correct">Sa DLSU lang ako <marker>nagkakasakit</marker> ngayon.</example>
		
		</rule>
	</category>
</rules>
